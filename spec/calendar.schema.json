{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Ethosism/ethos-calendar/spec/calendar.schema.json",
  "title": "Ethos Calendar",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "name",
    "status",
    "purpose",
    "principle",
    "authority",
    "source_docs",
    "non_goals",
    "daily_rule",
    "weekly_rule",
    "monthly_observances",
    "seasonal_cycle",
    "annual_days",
    "life_rites",
    "quality_gates",
    "production_ready_criteria"
  ],
  "properties": {
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "name": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "minLength": 1 },
    "purpose": { "type": "string", "minLength": 1 },
    "principle": { "type": "string", "minLength": 1 },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["canon", "language", "practice"],
      "properties": {
        "canon": { "type": "string", "minLength": 1 },
        "language": { "type": "string", "minLength": 1 },
        "practice": { "type": "string", "minLength": 1 }
      }
    },
    "source_docs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "annual_observance_calendar",
        "daily_weekly_rule",
        "year_cycle",
        "life_rites",
        "governance",
        "adoption_guide",
        "release_checklist"
      ],
      "properties": {
        "annual_observance_calendar": { "$ref": "#/$defs/docPath" },
        "daily_weekly_rule": { "$ref": "#/$defs/docPath" },
        "year_cycle": { "$ref": "#/$defs/docPath" },
        "life_rites": { "$ref": "#/$defs/docPath" },
        "governance": { "$ref": "#/$defs/docPath" },
        "adoption_guide": { "$ref": "#/$defs/docPath" },
        "release_checklist": { "$ref": "#/$defs/docPath" }
      }
    },
    "non_goals": { "$ref": "#/$defs/stringList" },
    "daily_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "recurrence", "purpose", "minimum_duration_minutes", "practices"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "recurrence": { "const": "daily" },
        "purpose": { "type": "string", "minLength": 1 },
        "minimum_duration_minutes": { "type": "integer", "minimum": 1 },
        "practices": {
          "type": "array",
          "minItems": 3,
          "items": { "$ref": "#/$defs/practice" }
        }
      }
    },
    "weekly_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "recurrence", "purpose", "days"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "recurrence": { "const": "weekly" },
        "purpose": { "type": "string", "minLength": 1 },
        "days": {
          "type": "array",
          "minItems": 7,
          "items": { "$ref": "#/$defs/weeklyDay" }
        }
      }
    },
    "monthly_observances": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/observance" }
    },
    "seasonal_cycle": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/season" }
    },
    "annual_days": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/annualDay" }
    },
    "life_rites": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/lifeRite" }
    },
    "quality_gates": { "$ref": "#/$defs/stringList" },
    "production_ready_criteria": { "$ref": "#/$defs/stringList" }
  },
  "$defs": {
    "stringList": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "practice": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "prompt", "ethos_function", "ethra_hinge", "visible_output"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "name": { "type": "string", "minLength": 1 },
        "prompt": { "type": "string", "minLength": 1 },
        "ethos_function": { "type": "string", "minLength": 1 },
        "ethra_hinge": { "type": "string", "minLength": 1 },
        "visible_output": { "type": "string", "minLength": 1 }
      }
    },
    "weeklyDay": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "theme", "prompt"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "theme": { "type": "string", "minLength": 1 },
        "prompt": { "type": "string", "minLength": 1 }
      }
    },
    "observance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "recurrence", "purpose", "visible_output"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "name": { "type": "string", "minLength": 1 },
        "recurrence": { "const": "monthly" },
        "purpose": { "type": "string", "minLength": 1 },
        "visible_output": { "type": "string", "minLength": 1 }
      }
    },
    "season": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "season", "focus"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "season": { "type": "string", "minLength": 1 },
        "focus": { "type": "string", "minLength": 1 }
      }
    },
    "annualDay": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "recurrence", "function"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "name": { "type": "string", "minLength": 1 },
        "recurrence": { "const": "annual" },
        "function": { "type": "string", "minLength": 1 }
      }
    },
    "lifeRite": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "status", "purpose"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "name": { "type": "string", "minLength": 1 },
        "status": {
          "type": "string",
          "enum": ["draft", "proposed", "experimental", "accepted", "deprecated", "rejected"]
        },
        "purpose": { "type": "string", "minLength": 1 }
      }
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "docPath": {
      "type": "string",
      "pattern": "^docs/.+\\.md$"
    }
  }
}
